# Ollama
OLLAMA_HOST=http://10.1.8.10:11500

MODEL_NAME=llama3.1:8b
LIGHT_MODEL=llama3.1:8b
# llama3.1:8b
# mistral-nemo

# MongoDB (Primary source for rules)
# Rules are loaded from MongoDB. If unavailable, falls back to data/rules.json
MONGO_URI=mongodb://10.1.8.10:27017/
MONGO_DB=compliance

# ChromaDB vector RAG (optional; set to true to enable)
USE_CHROMA=false
CHROMA_PERSIST_DIR=.chroma

# Pipeline tuning
MAX_WORKERS=4

# ── Deterministic LLM Settings (for reproducible outputs) ────────────────────
LLM_TEMPERATURE=0.0          # 0.0 = fully deterministic (was 0.1)
LLM_TOP_K=1                  # Only consider top 1 token
LLM_TOP_P=1.0                # Disable nucleus sampling
LLM_REPEAT_PENALTY=1.0       # No penalty variance
LLM_SEED=42                  # Fixed random seed (requires Ollama 0.2.0+)

LLM_MAX_TOKENS=2048          # Increased to accommodate amplification text
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY=2.0

# ── LLM Response Caching (guarantees identical outputs) ──────────────────────
USE_LLM_CACHE=true           # Enable caching for reproducibility
